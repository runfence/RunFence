<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <UseWindowsForms>true</UseWindowsForms>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Authors>Vladyslav (RunFence)</Authors>
        <Company>Vladyslav (RunFence)</Company>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
        <ApplicationManifest>app.debug.manifest</ApplicationManifest>
        <ApplicationIcon>app.debug.ico</ApplicationIcon>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' != 'Debug'">
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <ApplicationIcon>app.ico</ApplicationIcon>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="RunFence.Tests"/>
        <InternalsVisibleTo Include="DynamicProxyGenAssembly2"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\RunFence.Core\RunFence.Core.csproj"/>
        <ProjectReference Include="..\RunFence.Launching\RunFence.Launching.csproj"/>
        <ProjectReference Include="..\RunFence.FolderBrowser\RunFence.FolderBrowser.csproj"/>
        <ProjectReference Include="..\RunFence.Launcher\RunFence.Launcher.csproj"/>
        <ProjectReference Include="..\RunFence.DragBridge\RunFence.DragBridge.csproj"/>
        <ProjectReference Include="..\RunFence.JobKeeper\RunFence.JobKeeper.csproj"/>
        <ProjectReference Include="..\RunFence.PinHelper\RunFence.PinHelper.csproj"/>
        <ProjectReference Include="..\preftrans\preftrans.csproj"/>
        <ProjectReference Include="..\RunFence.SecurityScanner\RunFence.SecurityScanner.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="RunFence-autostart.cmd">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="unlock.cmd">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="unlock-operation.cmd">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="unregister-folder-handler.cmd">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <EmbeddedResource Include="Account\install-claude-code.ps1"/>
        <EmbeddedResource Include="app.ico" Condition="'$(Configuration)' != 'Debug'">
            <LogicalName>RunFence.app.ico</LogicalName>
        </EmbeddedResource>
        <EmbeddedResource Include="app.debug.ico" Condition="'$(Configuration)' == 'Debug'">
            <LogicalName>RunFence.app.ico</LogicalName>
        </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Autofac"/>
        <ProjectReference Include="..\..\lib\Autofac.Extras.Ordering\src\Autofac.Extras.Ordering\Autofac.Extras.Ordering.csproj"/>
        <PackageReference Include="BouncyCastle.Cryptography"/>
        <PackageReference Include="System.Management"/>
        <PackageReference Include="System.DirectoryServices.AccountManagement"/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.WindowsDesktop.App" />
    </ItemGroup>

</Project>
