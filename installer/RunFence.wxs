<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

  <Package Name="RunFence"
           Manufacturer="Vladyslav"
           Version="$(var.ProductVersion)"
           UpgradeCode="{186E1B82-D95C-492E-B910-BC80B3E46EEA}"
           Scope="perMachine">
    <!--
      UpgradeCode: DO NOT change after first release — breaks upgrades.
      Scope="perMachine": MSI requires elevation automatically, installs to ProgramFiles64Folder.
      Architecture is x64 via -arch x64 on the wix build command (not a Package attribute in WiX v4).
      ProductVersion is passed from the build script via: wix build -d ProductVersion=1.0.0
      UPDATE: set ARPHELPLINK and ARPURLINFOABOUT to the actual GitHub URL before publishing.
    -->

    <MajorUpgrade DowngradeErrorMessage="A newer version of RunFence is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!--
      .NET 10 WindowsDesktop Runtime x64 prerequisite.
      DotNetCompatibilityCheck uses the .NET host's own detection with LatestMinor roll-forward,
      so any 10.x.x patch version satisfies the requirement. This is a safety net for direct MSI
      installs; the bundle (Bundle.wxs) installs the runtime automatically before running this MSI.
    -->
    <netfx:DotNetCompatibilityCheck Property="DOTNET10PRESENT"
                                     RuntimeType="desktop"
                                     Platform="x64"
                                     Version="10.0.0"
                                     RollForward="LatestMinor" />
    <Launch Condition="Installed OR DOTNET10PRESENT"
            Message="RunFence requires .NET 10 Windows Desktop Runtime (x64). Download it from microsoft.com/dotnet, then re-run this installer." />

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="RunFence" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="RunFenceMenuFolder" Name="RunFence" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- Application icon for Add/Remove Programs -->
    <Icon Id="RunFenceIcon" SourceFile="..\src\RunFence\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="RunFenceIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/your-repo-url-here/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/your-repo-url-here" />

    <!-- Features -->
    <Feature Id="MainFeature" Title="RunFence" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!--
      Start Menu shortcuts component.
      RegistryValue with KeyPath="yes" is required — MSI shortcuts cannot be KeyPaths.
    -->
    <Component Id="StartMenuShortcuts"
               Directory="RunFenceMenuFolder"
               Guid="{A09BD112-811F-4B64-A8D7-D5E9037D812F}">
      <Shortcut Id="StartMenuShortcut"
                Name="RunFence"
                Target="[INSTALLFOLDER]RunFence.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="RunFenceIcon" />
      <Shortcut Id="UninstallShortcut"
                Name="Uninstall RunFence"
                Target="[SystemFolder]msiexec.exe"
                Arguments="/x [ProductCode]" />
      <RemoveFolder Id="RemoveRunFenceMenuFolder"
                    Directory="RunFenceMenuFolder"
                    On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\RunFence\Install"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!--
      Desktop shortcut component.
    -->
    <Component Id="DesktopShortcut"
               Directory="DesktopFolder"
               Guid="{62CD6019-A973-49D5-9330-560B76F8367D}">
      <Shortcut Id="DesktopShortcutLink"
                Name="RunFence"
                Target="[INSTALLFOLDER]RunFence.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="RunFenceIcon" />
      <RegistryValue Root="HKCU" Key="Software\RunFence\DesktopShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Standard install wizard UI with directory selection -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!--
      WixUI_InstallDir shows a license page by default.
      License.rtf is generated by build-installer.ps1 from LICENSE.md + THIRD-PARTY-NOTICES.txt.
    -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>

</Wix>
