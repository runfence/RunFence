<?xml version="1.0" encoding="UTF-8"?>
<!--
  Burn bootstrapper bundle — online installer.
  Embeds only the RunFence MSI; .NET 10 Windows Desktop Runtime is downloaded from
  Microsoft CDN at INSTALL TIME and only when not already installed on the target machine.

  At build time, build-installer.ps1 downloads the runtime temporarily to let WiX
  compute its SHA-512 hash and size (required for install-time integrity verification),
  then deletes it immediately — it is never embedded in the bundle EXE.

  Build (from build-installer.ps1 — handles downloading and cleanup automatically):
    wix build Bundle.wxs
         -ext WixToolset.BootstrapperApplications.wixext
         -ext WixToolset.Netfx.wixext
         -b <installer-dir>
         -d ProductVersion=1.0.XXX
         -d MsiPath=<absolute-path>.msi
         -d DotNet10RuntimePath=<absolute-path>.exe
         -d DotNet10DownloadUrl=https://...version-specific-url...
         -o Output\RunFence-Setup-1.0.XXXXXXXX.exe

  UpgradeCode: DO NOT change after first release — separate from the MSI UpgradeCode.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

  <Bundle Name="RunFence"
          Version="$(var.ProductVersion)"
          Manufacturer="Vladyslav"
          UpgradeCode="{3D8A1F6C-92E4-4B7D-A053-C5F2B8E91D40}">

    <!--
      WixStandardBootstrapperApplication: rtfLicense theme shows the RTF license page,
      progress, and finish — no install-directory picker (RunFence installs to Program Files).
      License.rtf is generated by build-installer.ps1 from LICENSE.md + THIRD-PARTY-NOTICES.txt.
      Resolved via -b <installer-dir> basepath.
    -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        LicenseFile="License.rtf"
        Theme="rtfLicense"
        SuppressOptionsUI="yes" />
    </BootstrapperApplication>

    <!--
      Detect any installed .NET 10.x Windows Desktop Runtime x64 using netcoresearch.exe
      (shipped inside WixToolset.Netfx.wixext). Sets DotNet10Detected to the version string
      if found, empty if not. MajorVersion="10" matches any 10.x.x patch.
    -->
    <netfx:DotNetCoreSearch Variable="DotNet10Detected"
                             RuntimeType="desktop"
                             Platform="x64"
                             MajorVersion="10" />

    <Chain>
      <!--
        .NET 10 Windows Desktop Runtime x64 — downloaded from Microsoft CDN at install time,
        only when DotNet10Detected is empty (no 10.x.x runtime present on the machine).
        SourceFile is the build-time copy used only for hash computation; Compressed="no"
        means it is NOT embedded. DotNet10DownloadUrl is the version-specific CDN URL
        captured from the aka.ms redirect so the hash always matches at install time.
      -->
      <ExePackage Id="DotNet10DesktopRuntime"
                  DisplayName=".NET 10 Windows Desktop Runtime (x64)"
                  PerMachine="yes"
                  Permanent="yes"
                  DetectCondition="DotNet10Detected"
                  InstallArguments="/quiet /norestart"
                  RepairArguments="/repair /quiet /norestart">
        <ExePackagePayload SourceFile="$(var.DotNet10RuntimePath)"
                           DownloadUrl="$(var.DotNet10DownloadUrl)"
                           Compressed="no" />
      </ExePackage>

      <!--
        RunFence MSI — compressed into the bundle EXE, installed silently after .NET.
        MsiPath is passed via -d MsiPath=... from build-installer.ps1.
      -->
      <MsiPackage SourceFile="$(var.MsiPath)"
                  DisplayName="RunFence"
                  Compressed="yes" />
    </Chain>

  </Bundle>

</Wix>
